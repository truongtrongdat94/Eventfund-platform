PORT=4000
NODE_ENV=Dev

MONGO_DEV_URI=mongodb+srv://
MONGO_PROD_URI=mongodb+srv://

# Cloudinary Configuration
# Base credentials (fallback if environment-specific not set)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Development environment credentials
CLOUDINARY_DEV_NAME=
CLOUDINARY_DEV_KEY=
CLOUDINARY_DEV_SECRET=

# Production environment credentials
CLOUDINARY_PROD_NAME=
CLOUDINARY_PROD_KEY=
CLOUDINARY_PROD_SECRET=

# Optional Cloudinary settings
CLOUDINARY_UPLOAD_FOLDER=uploads
MAX_IMAGE_SIZE_MB=5
MAX_EVENT_IMAGES=10

JWT_SECRET=secret
JWT_EXPIRES_IN=7d

SIWE_DOMAIN=localhost:4000
SIWE_URI=http://localhost:4000
SIWE_CHAIN_ID=1

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info