# ===== Contract Addresses (Update after deployment) =====
FUND_ADDRESS=0x0000000000000000000000000000000000000000
TICKET_ADDRESS=0x0000000000000000000000000000000000000000
MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000

# ===== Database =====
MONGO_DEV_URI=mongodb+srv://username:password@cluster.mongodb.net/eventfund-dev
MONGO_PROD_URI=mongodb+srv://username:password@cluster.mongodb.net/eventfund-prod

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== Authentication =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ===== Cloudinary =====
CLOUDINARY_DEV_NAME=your-cloud-name
CLOUDINARY_DEV_KEY=your-api-key
CLOUDINARY_DEV_SECRET=your-api-secret

CLOUDINARY_PROD_NAME=your-cloud-name
CLOUDINARY_PROD_KEY=your-api-key
CLOUDINARY_PROD_SECRET=your-api-secret

# ===== SIWE (Sign-In with Ethereum) =====
SIWE_DOMAIN=localhost:4000
SIWE_URI=http://localhost:4000
SIWE_CHAIN_ID=11155111

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ===== Logging =====
LOG_LEVEL=info

# ===== Blockchain (for contract deployment) =====
DEPLOYER_PRIVATE_KEY=your-wallet-private-key-without-0x-prefix
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-infura-key
